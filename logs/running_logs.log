[2025-11-25 12:02:38,056;INFO;projects;[DELETE PROJECT] Project deleted: [{'id': '9c4820ea-5851-445b-8b25-700abe7552ac', 'user_id': 'bc77eb3d-e3ba-4a2f-b5dd-a2543630a3ff', 'title': 'MLP Project', 'description': 'This is a description', 'spec_path': '9c4820ea-5851-445b-8b25-700abe7552ac/MLP2025_26_CW2_Spec.pdf', 'summary_json': {'extra': {'github_url': None, 'late_policy': 'If you do not submit anything before the deadline, you may submit exactly once after the deadline up to a maximum of 7 calendar days.', 'other_notes': 'This coursework is identical to Coursework1, and the repository branch mlp2025-26/coursework1 on the course Github holds the code and data-related additions.', 'extension_policy': 'Guidance on late submissions is at https://informatics.ed.ac.uk/taught-students/all-students/your-studies/late-coursework-extension-requests Do not email any course staff directly about extension requests; you must follow the instructions on the web page.'}, 'tasks': [{'id': '732b9600-bbab-4c9b-b592-a778c97e671a', 'task': 'Problem identification', 'source_sentence': '5 Task 1: Problem identification'}, {'id': '1a276b96-ca20-4783-8996-113fad0e3586', 'task': 'Mitigating the problem with regularization', 'source_sentence': '6 Task 2: Mitigating the problem with regularization'}, {'id': '4a8248db-d144-4443-9b3e-3e9495c8290c', 'task': 'Conclusions', 'source_sentence': '7 Task 3: Conclusions'}], 'datasets': [{'name': 'EMNIST Balanced dataset', 'details': 'Extended MNIST with handwritten digits and letters; reduced label set to 47; images are 28x28.'}], 'deadline': '2025-11-21T12:00:00', 'weighting': None, 'deliverables': [{'name': 'Final report (Sxxxxxx_report.pdf)', 'details': 'Submitted as PDF file using the provided LaTeX/template, containing the coursework questions and analysis.'}, {'name': 'MLP coursework code package', 'details': 'Local version of the mlp code including any changes to modules (.py files).'}, {'name': 'Coursework_1.ipynb', 'details': 'Notebook with experiment setup (Coursework_1.ipynb).'}, {'name': 'Regularization test pack', 'details': 'xxxxxx_regularization_test_pack.npy generated by scripts/generate_regularization_layer_test_outputs.py.'}], 'description_long': 'The coursework uses an extended EMNIST Balanced dataset derived from MNIST, with 47 labels after merging certain upper/lowercase pairs, and 28x28 images. It tasks students with analyzing a fundamental machine learning problem (overfitting), building baselines, and exploring network width and depth. Students implement and evaluate regularization techniques (DropoutLayer, L1Penalty, L2Penalty, L1L2MixPenalty) and a custom activation layer, compare their effects empirically, and discuss how these approaches relate to literature. Deliverables include a report, accompanying code modifications, and experiment artifacts, submitted as a zipped package.', 'methods_required': ['DropoutLayer', 'L1Penalty', 'L2Penalty', 'L1L2MixPenalty', 'Label smoothing', 'CustomActivationLayer', 'Adam optimizer'], 'description_short': 'MLP2025/26: Coursework 2 focuses on handwritten digit classification using neural networks on an extended MNIST/EMNIST Balanced dataset. It begins with identifying a fundamental problem (overfitting) and setting up a baseline system, then investigates regularization methods including dropout, L1/L2 penalties, label smoothing, and a proposed L1/L2 mix. The coursework requires implementing new layers and penalties, running experiments with Adam optimizer, and comparing methods both empirically and theoretically. The final deliverable is a report, along with code, notebooks, and test outputs submitted as a zip package.', 'evaluation_metrics': ['training error', 'validation error', 'training accuracy', 'validation accuracy', 'test accuracy'], 'submission_requirements': ['Submit a zip file named Sxxxxxx.zip containing: xxxxxx_regularization_test_pack.npy, Sxxxxxx_report.pdf, your completed mlp code including any changes to the modules and the Coursework_1.ipynb notebook.']}, 'created_at': '2025-11-25T11:43:44.29296+00:00', 'updated_at': None, 'deadline': '2026-01-14T00:00:00+00:00'}]]
