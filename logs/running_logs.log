[2025-11-25 11:32:38,149;INFO;projects;[DELETE PROJECT] Project deleted: [{'id': '036f5566-8de7-4507-8e4e-5827a0efcd20', 'user_id': 'bc77eb3d-e3ba-4a2f-b5dd-a2543630a3ff', 'title': 'MLP Project', 'description': 'This is a description', 'spec_path': '036f5566-8de7-4507-8e4e-5827a0efcd20/MLP2025_26_CW2_Spec.pdf', 'summary_json': {'extra': {'github_url': 'https://github.com/orgs/mlpractical/repositories (branch: mlp2025-26/coursework1)', 'late_policy': 'If you submit anything before the deadline, you may not resubmit after the deadline. If you do not submit anything before the deadline, you may submit exactly once after the deadline up to a maximum of 7 calendar days.', 'other_notes': 'Recommended workload: 5 hours for Coursework 1, 10 hours for Coursework 2. Use (mini-)Conda environment set up for labs. Academic conduct subject to University regulations: http://web.inf.ed.ac.uk/infweb/admin/policies/academic-misconduct. Work should be backed up regularly. Keep coursework under version control in Git repository but do not share public instances.', 'extension_policy': 'Do not email any course staff directly about extension requests; you must follow the instructions on the webpage at https://informatics.ed.ac.uk/taught-students/all-students/your-studies/late-coursework-extension-requests'}, 'tasks': [{'id': 'b3fe0456-fb58-41a8-aabb-20ddb59f1df0', 'task': 'Implement DropoutLayer in mlp.layers module', 'source_sentence': 'Implement the Dropout class in the DropoutLayer of the mlp.layers module.'}, {'id': '36df5e7c-af68-46eb-a58e-53e585c655a9', 'task': 'Implement L1Penalty and L2Penalty classes in mlp.penalties module', 'source_sentence': 'Implement the L1Penalty and L2Penalty class in the L1Penalty and L2Penalty of the mlp.penalties module.'}, {'id': '9d20cbf3-3710-47a9-862c-d725457f9be0', 'task': 'Test implementations using DropoutandPenalty_tests.ipynb', 'source_sentence': 'Verify the correctness of your implementation using the supplied unit tests in DropoutandPenalty_tests.ipynb'}, {'id': '7c61c746-801b-488e-822a-05e23119d515', 'task': 'Generate test outputs file', 'source_sentence': 'Automatically create test outputs xxxxxx_regularization_test_pack.npy, by running the provided program scripts/generate_regularization_layer_test_outputs.py'}, {'id': '4442b979-33e1-442b-beff-483eaf0f2af0', 'task': 'Implement label_smoothing function in EMNISTDataProvider', 'source_sentence': 'To implement the labelsmoothing function, fill in label_smoothing function in EMNISTDataProvider class of data_providers.py'}, {'id': 'f4dfaaa7-8a86-4d12-9880-cb4cba477e3f', 'task': 'Implement L1L2MixPenalty in mlp.penalties module', 'source_sentence': 'Implement your proposed L1 and L2 combined weight penalty, as the L1L2MixPenalty in the mlp.penalties module.'}, {'id': '4025db65-1a38-47ff-864d-3b287ec63140', 'task': 'Train networks with varying hidden units (32, 64, 128)', 'source_sentence': 'Initially you will train various 1-hidden layer networks by using either 32, 64 and 128 ReLU hidden units per layer on EMNIST.'}, {'id': '7ca7e511-8945-446b-ba98-4eac0d73be0b', 'task': 'Train networks with varying number of layers (1, 2, 3)', 'source_sentence': 'Here you will train various neural networks by using either 1, 2, 3 hidden layers with 128 ReLU hidden units per layer on EMNIST.'}, {'id': 'ce689a2f-4f26-4918-92ad-e5b51fec4087', 'task': 'Modify baseline network to use regularization techniques', 'source_sentence': 'In this section you should modify your baseline network to one that uses DropoutLayer, L1Penalty, or L2Penalty and train a model for each case.'}, {'id': '42087c2c-39ff-41bf-b6a1-37f748756328', 'task': 'Run experiment with baseline setup plus label smoothing', 'source_sentence': 'You will also run one experiment with the baseline setup plus label smoothing, using no other regularization techniques.'}, {'id': '227e5c0e-c130-4148-a479-46764a130d98', 'task': 'Run 4 different hyperparameter combinations for L1L2MixPenalty', 'source_sentence': 'You will have to identify and argue for a set of 4 different hyperparameter combinations for which you will run the combined L1 and L2 experiments.'}, {'id': 'a8b0fc0b-2599-4bad-8273-024887ba9b93', 'task': 'Investigate performance problems with CustomActivationLayer', 'source_sentence': 'You will finally investigate and explain the performance problems with a provided model setup and experiment run, that uses a custom activation layer.'}, {'id': 'a093f854-8925-48b5-a91e-11c6481771c5', 'task': 'Answer all questions in mlp-cw1-questions.tex', 'source_sentence': 'The questions in (mlp-cw1-questions.tex) that you must answer and count for this task are:'}], 'datasets': [{'name': 'EMNIST Balanced dataset', 'details': 'Extended MNIST with handwritten letters (upper and lowercase) and digits, 47 different labels (merging upper/lower case for specific letters), 28×28 centered images, training set has about twice the number of examples as MNIST'}, {'name': 'MNIST dataset', 'details': 'Related dataset used for comparison, extracted from same underlying NIST Special Database 19'}], 'deadline': '2025-11-21T12:00:00', 'weighting': '50% of final grade; 100 marks total', 'deliverables': [{'name': 'Report as PDF file', 'details': 'Using provided template, renamed as Sxxxxxx_report.pdf'}, {'name': 'Local version of mlp code', 'details': 'Including any changes to provided .py files and Coursework_1.ipynb notebook'}, {'name': 'Test outputs file', 'details': 'xxxxxx_regularization_test_pack.npy generated using scripts/generate_regularization_layer_test_outputs.py'}, {'name': 'Submission zip file', 'details': 'Sxxxxxx.zip containing all above files'}], 'description_long': None, 'methods_required': ['Neural networks with ReLU activation', 'Dropout', 'L1Penalty', 'L2Penalty', 'L1L2MixPenalty (combined L1 and L2)', 'Label smoothing', 'CustomActivationLayer', 'Adam optimiser'], 'description_short': 'This coursework studies the classification of handwritten digits using neural networks, focusing on identifying and addressing overfitting problems. Students investigate fundamental machine learning issues in wider and deeper neural networks through network width and depth analysis. The second part involves implementing different methods to combat identified problems and comparing these methods empirically and theoretically. The final part requires presenting conclusions and contextualizing them in the literature. The coursework uses the EMNIST Balanced dataset and requires a comprehensive report as the main deliverable.', 'evaluation_metrics': ['Validation accuracy', 'Test accuracy', 'Training and validation error curves', 'Training and validation accuracy curves'], 'submission_requirements': ['Submit Sxxxxxx.zip file through Learn webpage', 'ZIP must contain: mlp/ directory, Coursework_1.ipynb, Sxxxxxx_report.pdf, xxxxxx_regularization_test_pack.npy', 'Report must be PDF format using provided LaTeX template', 'Code changes must be to .py files in mlp module', 'File size should be few MB only (no model weights)', 'Use Linux command: zip -r Sxxxxxx.zip mlp/ Coursework_1.ipynb Sxxxxxx_report.pdf xxxxxx_regularization_test_pack.npy']}, 'created_at': '2025-11-25T00:58:20.465364+00:00', 'updated_at': None, 'deadline': '2026-01-14T00:00:00+00:00'}]]
